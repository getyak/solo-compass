# Solo Compass environment configuration template.
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# Build-time: `scripts/generate_secrets.sh` transforms `.env` into
#   apps/ios/SoloCompass/Config/GeneratedSecrets.swift
# Runtime (Node): bot/web read these vars directly via `process.env`.

# ─── DeepSeek (AI ranking + experience structuring — OpenAI-compatible) ───────
# Get your API key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# ─── Tavily (web search for the compile-city-brief Edge Function) ─────────────
# Get a key at: https://app.tavily.com — used server-side only to source the
# landing kit / live events. Never ships to clients.
TAVILY_API_KEY=tvly-replace-me
# Shared secret the GitHub `city-brief-refresh` cron sends as `x-cron-secret`
# (the cron does not hold the service-role key). Also set as a Supabase secret.
CITY_BRIEF_CRON_SECRET=replace-with-long-random-string

# ─── Mapbox (web map rendering) ───────────────────────────────────────────────
# Get one free: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=pk.eyJ...
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# ─── Amap / AutoNavi (mainland-China POI source, iOS only) ────────────────────
# Web-service key from https://console.amap.com → 应用管理 → 我的应用 →
# create app → add key with service "Web服务" (REST). Used by AmapPOIService for
# explore inside mainland China, where OSM coverage is ~9× sparser than reality.
# Empty value → the China branch transparently degrades to Overpass.
AMAP_API_KEY=

# ─── Supabase (data persistence) ──────────────────────────────────────────────
# Create a free project: https://supabase.com
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...              # public, ships with iOS / web bundles
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # server-only, NEVER ships to clients

# ─── Telegram bot (only needed for apps/bot) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Apple Developer (iOS only) ───────────────────────────────────────────────
DEVELOPMENT_TEAM=XXXXXXXXXX

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
# Get a DSN at: https://sentry.io → Settings → Projects → <project> → Client Keys
# Empty value disables Sentry on iOS (SentryService.bootstrap becomes a no-op);
# DSN is baked into the iOS binary at build time via scripts/generate_secrets.sh.
SENTRY_DSN=
# Same value as SENTRY_DSN but exposed to browser bundles via Next.js public env
NEXT_PUBLIC_SENTRY_DSN=

# ─── PostHog (cost telemetry) ─────────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
