*~
.DS_Store

# iOS
apps/ios/Pods/
apps/ios/build/
apps/ios/DerivedData/
apps/ios/.build/
apps/ios/*.xcworkspace/xcuserdata/
apps/ios/**/xcuserdata/
*.xcuserstate

# Generated from .env at build time — never commit
apps/ios/SoloCompass/Config/GeneratedSecrets.swift
apps/ios/SoloCompass/Resources/Secrets.plist

# Data caches (large, regenerable)
.cache/
seeds/raw/
data/cache/
*.pbf
*.osm

# Test
coverage/
.nyc_output/

# Misc
.eslintcache
.prettiercache
*.tgz

# Claude Code internal prompts (auto-generated)
.claude/*-prompt.txt
.claude/worktrees/
.claude/scheduled_tasks.lock
Gemfile.lock
__pycache__/

# sc-evaluator screenshot artifacts (per-run PNGs).
# Opt-in retention: run with SC_EVALUATOR_KEEP_SCREENSHOTS=1 to have run.sh
# `git add -f` the current run's directory so it can be committed.
scripts/sc-evaluator/screenshots/

# Supabase CLI local link state (generated by `supabase link`); not source.
infra/supabase/.temp/
infra/supabase/supabase/

# claude.ai/design handoff bundles — 30MB+ HTML with inlined base64 assets,
# downloaded as design reference material, not source we ship.
docs/design/incoming/

# Playwright MCP run artifacts (console logs, page snapshots) — transient.
.playwright-mcp/
