# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Build outputs
dist/
build/
out/
.next/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts

# Playwright / E2E artifacts (regenerated each run)
apps/web/test-results/
apps/web/playwright-report/
apps/web/e2e/report/

# Environment
.env
.env.local
.env.*.local
.env.development
.env.production
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store

# iOS
apps/ios/Pods/
apps/ios/build/
apps/ios/DerivedData/
apps/ios/.build/
apps/ios/*.xcworkspace/xcuserdata/
apps/ios/**/xcuserdata/
*.xcuserstate

# Generated from .env at build time — never commit
apps/ios/SoloCompass/Config/GeneratedSecrets.swift
apps/ios/SoloCompass/Resources/Secrets.plist

# Data caches (large, regenerable)
.cache/
seeds/raw/
data/cache/
*.pbf
*.osm

# Test
coverage/
.nyc_output/

# Misc
.eslintcache
.prettiercache
*.tgz

# Claude Code internal prompts (auto-generated)
.claude/*-prompt.txt
.claude/worktrees/
.claude/scheduled_tasks.lock
Gemfile.lock
__pycache__/

# sc-evaluator screenshot artifacts (per-run PNGs).
# Opt-in retention: run with SC_EVALUATOR_KEEP_SCREENSHOTS=1 to have run.sh
# `git add -f` the current run's directory so it can be committed.
scripts/sc-evaluator/screenshots/

# Supabase CLI local link state (generated by `supabase link`); not source.
infra/supabase/.temp/
infra/supabase/supabase/

# claude.ai/design handoff bundles — 30MB+ HTML with inlined base64 assets,
# downloaded as design reference material, not source we ship.
docs/design/incoming/

# Playwright MCP run artifacts (console logs, page snapshots) — transient.
.playwright-mcp/

# Rubric evidence: PNGs from the multi-agent scoring runs. Markdown reports
# (EVIDENCE.md / O1_FIXES.md / O3_P1_FIXES.md) stay tracked so the fix
# rationale survives; the ~3 MB-each screenshots do not need git history.
apps/ios/rubric_evidence/*.png
apps/ios/rubric_evidence/*.log
apps/ios/rubric_evidence/*.txt

# Per-round snapshots from user_stories.round{N} dirs are ephemeral; the
# canonical latest round lives at apps/ios/rubric_evidence/user_stories/.
apps/ios/rubric_evidence/user_stories.round*/

# Seed backup created before schema experiments; regenerated on demand.
apps/ios/SoloCompass/Resources/JSON/seed_experiences.json.backup

# Scratch skill directories (sc-evaluator/sc-executor/sc-loop) that live
# alongside the shipping code but aren't part of the app build.
.agents/skills/
